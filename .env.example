# === Dev + Prod ===

# AWS Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=""
NEXT_PUBLIC_COGNITO_CLIENT_ID=""

# AES-256-GCM key for encrypting stored API keys (64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# === Dev only ===

# Database (used by the app container — "db" is the Podman Compose service name)
DATABASE_URL="postgresql://fray:fray@db:5432/fray"

# SearXNG ("searxng" is the Podman Compose service name)
SEARXNG_URL="http://searxng:8080"

# Ollama host (for container→host access, use host.containers.internal)
# Omit for local dev (defaults to http://localhost:11434)
# OLLAMA_HOST="http://host.containers.internal:11434"

# === Prod only (podman-compose.prod.yml) ===

# Domain for Caddy auto-SSL (e.g. fray.example.com)
# DOMAIN=""

# Postgres credentials (prod compose constructs DATABASE_URL from these)
# POSTGRES_USER=""
# POSTGRES_PASSWORD=""
